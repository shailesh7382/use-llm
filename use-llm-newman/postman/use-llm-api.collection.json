    {
      "name": "20 - Prompts - create custom template",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"test-haiku\",\n  \"name\": \"Haiku Generator\",\n  \"description\": \"Generates a haiku on any topic\",\n  \"persona\": \"You are a renowned haiku poet who crafts vivid, evocative haikus.\",\n  \"systemPrompt\": \"A haiku has exactly three lines: 5 syllables, 7 syllables, 5 syllables. Always follow this structure.\",\n  \"userPromptTemplate\": \"Write a haiku about: {{topic}}\",\n  \"outputFormat\": \"Output only the three lines of the haiku, nothing else.\",\n  \"variables\": [\n    { \"name\": \"topic\", \"description\": \"The haiku subject\", \"required\": true }\n  ]\n}"
