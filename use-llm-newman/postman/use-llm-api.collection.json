{
  "info": {
    "_postman_id": "2df2f730-276f-4ab5-a59d-31fc8589ea9f",
    "name": "use-llm API tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Exhaustive Newman regression checks for use-llm-api endpoints."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId')) pm.environment.set('runId', String(Date.now()));",
          "if (!pm.environment.get('conversationId')) pm.environment.set('conversationId', '');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Models - list (query + limit)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/models?query={{searchQuery}}&limit=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "models"
          ],
          "query": [
            {
              "key": "query",
              "value": "{{searchQuery}}"
            },
            {
              "key": "limit",
              "value": "5"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('request succeeds', function () {",
              "  pm.expect(pm.response.code).to.be.a('number');",
              "});",
              "pm.test('status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('response is an array', function () {",
              "    pm.expect(Array.isArray(body)).to.eql(true);",
              "  });",
              "  if (Array.isArray(body) && body.length > 0 && body[0].id) {",
              "    pm.environment.set('modelId', body[0].id);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
