              "pm.test('status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('conversation id reused', function () {",
              "  pm.expect(body.conversationId).to.eql(pm.environment.get('conversationId'));",
              "});",
              "pm.test('memory size has grown', function () {",
              "  pm.expect(body.memorySize).to.be.a('number');",
              "  pm.expect(body.memorySize).to.be.greaterThan(2);",
              "});"
            ]
          }
        }
      ]
